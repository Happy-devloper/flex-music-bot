{
  "name": "telegram-music-bot",
  "version": "0.1.0",
  "description": "Production-ready Telegram group music bot built with Node.js, TypeScript, grammY, MongoDB, FFmpeg, and yt-dlp.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "generate:session": "tsx scripts/generate-session.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "telegram",
    "music-bot",
    "grammy",
    "mongodb",
    "ffmpeg",
    "yt-dlp"
  ],
  "license": "MIT",
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/runner": "^2.0.3",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "execa": "^9.5.2",
    "ffmpeg-static": "^5.3.0",
    "gram-tgcalls": "^2.1.9",
    "grammy": "^1.34.0",
    "mongoose": "^8.9.5",
    "telegram": "^2.26.22",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "node-pre-gyp": "^0.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
